<?xml version="1.0" encoding="utf-8"?>
<androidx.cardview.widget.CardView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:layout_marginHorizontal="24dp"
    android:layout_marginVertical="6dp"
    app:cardCornerRadius="12dp"
    app:cardElevation="2dp">

    <RelativeLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:padding="16dp">

        <TextView
            android:id="@+id/txtNomeSala"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Sala 101"
            android:textColor="@color/navy_blue"
            android:textSize="16sp"
            android:textStyle="bold" />

        <TextView
            android:id="@+id/txtCapacidade"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_below="@id/txtNomeSala"
            android:layout_marginTop="4dp"
            android:text="Capacidade: 40 alunos"
            android:textColor="@color/gray_text"
            android:textSize="13sp" />

        <LinearLayout
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_below="@id/txtCapacidade"
            android:layout_marginTop="8dp"
            android:gravity="center_vertical"
            android:orientation="horizontal">

            <androidx.cardview.widget.CardView
                android:id="@+id/indicadorStatus"
                android:layout_width="10dp"
                android:layout_height="10dp"
                app:cardBackgroundColor="#10B981"
                app:cardCornerRadius="5dp"
                app:cardElevation="0dp"
                android:layout_marginEnd="6dp"/>

            <TextView
                android:id="@+id/txtStatusTexto"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Livre"
                android:textColor="#10B981"
                android:textSize="12sp"
                android:textStyle="bold" />
        </LinearLayout>

        <ImageView
            android:id="@+id/btnAdicionarAula"
            android:layout_width="36dp"
            android:layout_height="36dp"
            android:layout_alignParentEnd="true"
            android:layout_centerVertical="true"
            android:background="?attr/selectableItemBackgroundBorderless"
            android:clickable="true"
            android:focusable="true"
            android:padding="4dp"
            android:src="@android:drawable/ic_input_add"
            app:tint="@color/ibmec_yellow" />

    </RelativeLayout>
</androidx.cardview.widget.CardView>